				<key>script</key>
				<string>#!/usr/bin/env bash

# 1) 从 Keyboard Maestro 读取变量
STATE=$(osascript &lt;&lt;EOF
tell application "Keyboard Maestro Engine"
    getvariable "ClasVergeOpen"
end tell
EOF
)

# 2) 默认值保护
# 如果 KM 变量为空、或者不是 0/1，则认为是 “0” (即需要开启)
if [[ "$STATE" != "0" &amp;&amp; "$STATE" != "1" ]]; then
    STATE="0"
fi

# 3) 根据变量判断下一个动作
if [[ "$STATE" == "0" ]]; then
    NEXT_ACTION="ON"
else
    NEXT_ACTION="OFF"
fi

# 4) 输出 Alfred JSON
cat &lt;&lt;EOF
{
  "items": [
    {
      "uid": "tun_toggle",
      "title": "TUN $NEXT_ACTION",
      "subtitle": "Next action based on current state ($STATE)",
      "arg": "$NEXT_ACTION"
    }
  ]
}
EOF</string>
